[Unit]
Description=AMap ESP32 OTA sync job
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/amap-ota-update-server
Environment=GITHUB_REPO=zuo-qirun/Amap-for-ESP32
Environment=OTA_SYNC_SOURCE=release
Environment=OTA_SYNC_CHANNELS=stable,dev
Environment=OTA_WEB_ROOT=/opt/amap-ota-update-server/public/ota
# Environment=GITHUB_TOKEN=ghp_xxx
ExecStart=/usr/bin/node sync-build.mjs
User=www-data
