# HTTP server
HOST=0.0.0.0
PORT=8798
AUTO_SYNC=1
SYNC_INTERVAL_MS=3600000

# GitHub source
GITHUB_REPO=zuo-qirun/Amap-for-ESP32
# GITHUB_TOKEN=

# OTA sync behavior
OTA_SYNC_SOURCE=release
OTA_SYNC_CHANNELS=stable,dev
OTA_SYNC_STRICT_MISSING=0

# Local output
OTA_WEB_ROOT=./public/ota
OTA_SYNC_STATE_FILE=./state/sync-state.json

# Public URL used in deployment docs / future extensions
PUBLIC_BASE_URL=https://ota.zuoqirun.top
